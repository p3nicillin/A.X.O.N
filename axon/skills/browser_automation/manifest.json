{
  "name": "BrowserAutomationSkill",
  "version": "1.1.0",
  "description": "Controls an isolated Playwright browser with grounded element IDs and verified navigation, clicks, and form filling.",
  "intents": ["browser_navigate", "browser_read_page", "browser_click", "browser_fill", "browser_close_managed"],
  "intent_params": {
    "browser_navigate": ["url"],
    "browser_read_page": [],
    "browser_click": ["target", "element_id", "expected"],
    "browser_fill": ["field", "text", "element_id"],
    "browser_close_managed": []
  },
  "sensitive_intents": ["browser_click", "browser_fill"],
  "sensitive": false,
  "author": "core"
}
